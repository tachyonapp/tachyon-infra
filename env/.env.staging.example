# ============================================================================
# STAGING ENV TEMPLATE
# ============================================================================
# Actual values are set in DigitalOcean App Platform encrypted env vars.
# This file documents which variables must be configured.
# ============================================================================

POSTGRES_HOST=${tachyon-pg.HOSTNAME}
POSTGRES_PORT=${tachyon-pg.PORT}
POSTGRES_DB=${tachyon-pg.DATABASE}
POSTGRES_SSL=true
POSTGRES_MAX_CONNECTIONS=20

POSTGRES_APP_USER=${tachyon-pg.APP_USERNAME}
POSTGRES_APP_PASSWORD=${tachyon-pg.APP_PASSWORD}     

POSTGRES_MIGRATE_USER=${tachyon-pg.MIGRATE_USERNAME}
POSTGRES_MIGRATE_PASSWORD=${tachyon-pg.MIGRATE_PASSWORD} 

VALKEY_HOST=${tachyon-valkey.HOSTNAME}
VALKEY_PORT=${tachyon-valkey.PORT}
VALKEY_PASSWORD=${tachyon-valkey.PASSWORD}
VALKEY_TLS=true

NODE_ENV=staging
LOG_LEVEL=info

PORT=4000
CORS_ORIGIN=https://staging.tachyon.app

BULLMQ_CONCURRENCY=5

MIGRATION_ENV=staging

DB_ENCRYPTION_KEY=  # 32-byte hex; NEVER commit a real value here

NODE_AUTH_TOKEN=  # GitHub PAT (read:packages) — set in DigitalOcean App Platform