# ============================================================================
# STAGING ENV TEMPLATE
# ============================================================================
# Actual values are set in DigitalOcean App Platform encrypted env vars.
# This file documents which variables must be configured.
# ============================================================================

POSTGRES_HOST=${tachyon-pg-staging.HOSTNAME}
POSTGRES_PORT=${tachyon-pg-staging.PORT}
POSTGRES_DB=${tachyon-pg-staging.DATABASE}
POSTGRES_SSL=true
POSTGRES_MAX_CONNECTIONS=20

POSTGRES_APP_USER=${tachyon-pg-staging.APP_USERNAME}
POSTGRES_APP_PASSWORD=${tachyon-pg-staging.APP_PASSWORD}     

POSTGRES_MIGRATE_USER=${tachyon-pg-staging.MIGRATE_USERNAME}
POSTGRES_MIGRATE_PASSWORD=${tachyon-pg-staging.MIGRATE_PASSWORD} 

VALKEY_HOST=${tachyon-valkey-staging.HOSTNAME}
VALKEY_PORT=${tachyon-valkey-staging.PORT}
VALKEY_PASSWORD=${tachyon-valkey-staging.PASSWORD}
VALKEY_TLS=true

NODE_ENV=staging
LOG_LEVEL=info

PORT=4000
CORS_ORIGIN=https://staging.tachyon.app

BULLMQ_CONCURRENCY=5

MIGRATION_ENV=staging

DB_ENCRYPTION_KEY=  # 32-byte hex; NEVER commit a real value here

NODE_AUTH_TOKEN=  # GitHub PAT (read:packages) — set in DigitalOcean App Platform

BULL_BOARD_USERNAME=<set-in-do-secrets>
BULL_BOARD_PASSWORD=<set-in-do-secrets>
SENTRY_DSN=<set-in-do-secrets>

AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_JWKS_CACHE_TTL=600

# AUTH0 — tachyon-mobile Expo public vars
EXPO_PUBLIC_AUTH0_DOMAIN=                          # Same value as AUTH0_DOMAIN above
EXPO_PUBLIC_AUTH0_CLIENT_ID=                       # Auth0 Native application Client ID
EXPO_PUBLIC_AUTH0_AUDIENCE=                        # Same value as AUTH0_AUDIENCE above
EXPO_PUBLIC_API_URL=