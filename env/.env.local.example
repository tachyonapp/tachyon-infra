# ============================================================================
# LOCAL ENV TEMPLATE
# ============================================================================
# This file documents ALL environment variables used across Tachyon services.
# Copy the appropriate .env.{environment}.example file for your target.
# NEVER commit actual .env files to version control.
# ============================================================================

# ---------------------------------------------------------------------------
# Database — Shared
# ---------------------------------------------------------------------------
POSTGRES_HOST=                    # Database host (localhost | DO private URL)
POSTGRES_PORT=5432                # Database port
POSTGRES_DB=                      # Database name (tachyon_dev | tachyon_staging | tachyon_prod)
POSTGRES_SSL=false                # Enable SSL (false local | true staging/prod)
POSTGRES_MAX_CONNECTIONS=20       # Connection pool size

# ---------------------------------------------------------------------------
# Database — Application User (DML only, used by tachyon-api and tachyon-workers)
# ---------------------------------------------------------------------------
POSTGRES_APP_USER=tachyon_app
POSTGRES_APP_PASSWORD=               # Set in DigitalOcean App Platform secrets

# ---------------------------------------------------------------------------
# Database — Migration User (DDL privileges, used by tachyon-db migration runner only)
# ---------------------------------------------------------------------------
POSTGRES_MIGRATE_USER=tachyon_migrate
POSTGRES_MIGRATE_PASSWORD=            # Set in DigitalOcean App Platform secrets

# ---------------------------------------------------------------------------
# ValKey — Shared Cache/Queue
# ---------------------------------------------------------------------------
VALKEY_HOST=                      # ValKey host (localhost | DO private URL)
VALKEY_PORT=6379                   # ValKey port
VALKEY_PASSWORD=                   # ValKey password [SECRET] (empty for local)
VALKEY_TLS=false                   # Enable TLS (false local | true staging/prod)

# ---------------------------------------------------------------------------
# Runtime — Shared
# ---------------------------------------------------------------------------
NODE_ENV=development              # Environment (development | staging | production)
LOG_LEVEL=debug                   # Logging level (debug | info | warn | error)

# ---------------------------------------------------------------------------
# API Service
# ---------------------------------------------------------------------------
PORT=4000                         # API listen port
CORS_ORIGIN=                      # Allowed CORS origin (mobile app URL)

# ---------------------------------------------------------------------------
# Worker Service
# ---------------------------------------------------------------------------
BULLMQ_CONCURRENCY=5             # Worker concurrency limit

# ---------------------------------------------------------------------------
# Database Migration Runnger — Shared
# ---------------------------------------------------------------------------
MIGRATION_ENV=local               # Target environment (local | staging | production)

# ---------------------------------------------------------------------------
# Encryption — AES-256-GCM key for OAuth token encryption
# Generate: openssl rand -hex 32
# ---------------------------------------------------------------------------
DB_ENCRYPTION_KEY=                   # 32-byte hex; NEVER commit a real value here

# ---------------------------------------------------------------------------
# GitHub Packages — Auth token for installing @tachyonapp/tachyon-db
# ---------------------------------------------------------------------------
NODE_AUTH_TOKEN=                     # GitHub PAT with read:packages scope

# =============================================================================
# Bull Board Dashboard (tachyon-api only — dev + staging; NOT production)
# =============================================================================
BULL_BOARD_USERNAME=                   # Basic auth username for Bull Board. Staging only. Empty = no auth (local dev).
BULL_BOARD_PASSWORD=                   # Basic auth password for Bull Board. Staging only. Empty = no auth (local dev).

# =============================================================================
# Sentry Error Capture (tachyon-workers and tachyon-api only)
# =============================================================================
SENTRY_DSN=                            # Sentry DSN for error capture. Absent = Sentry disabled (local dev).

# =============================================================================
# CLERK Auth
# =============================================================================
CLERK_PUBLISHABLE_KEY=pk_test_aW52aXRpbmctbW9yYXktMjMuY2xlcmsuYWNjb3VudHMuZGV2JA
CLERK_SECRET_KEY=sk_test_ofYUe6AGqMyBbqL8mSa0OjdQ82Ctr3j4T0bC3nLLz0
CLERK_JWKS_URL=https://inviting-moray-23.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://inviting-moray-23.clerk.accounts.dev 
CLERK_JWKS_CACHE_TTL=600      # JWKS cache TTL in seconds (default 600)

# =============================================================================
# AI Config
# =============================================================================
TACHYON_BRAIN_DAILY_CAP=10
ANTHROPIC_API_KEY=