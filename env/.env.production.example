# ============================================================================
# PROD ENV TEMPLATE
# ============================================================================
# Actual values are set in DigitalOcean App Platform encrypted env vars.
# This file documents which variables must be configured.
# ============================================================================
POSTGRES_HOST=${tachyon-pg-prod.HOSTNAME}
POSTGRES_PORT=${tachyon-pg-prod.PORT}
POSTGRES_DB=${tachyon-pg-prod.DATABASE}
POSTGRES_SSL=true
POSTGRES_MAX_CONNECTIONS=20

POSTGRES_APP_USER=${tachyon-pg-prod.APP_USERNAME}
POSTGRES_APP_PASSWORD=${tachyon-pg-prod.APP_PASSWORD}     

POSTGRES_MIGRATE_USER=${tachyon-pg-prod.MIGRATE_USERNAME}
POSTGRES_MIGRATE_PASSWORD=${tachyon-pg-prod.MIGRATE_PASSWORD} 

VALKEY_HOST=${tachyon-valkey-prod.HOSTNAME}
VALKEY_PORT=${tachyon-valkey-prod.PORT}
VALKEY_PASSWORD=${tachyon-valkey-prod.PASSWORD}
VALKEY_TLS=true

NODE_ENV=production
LOG_LEVEL=info

PORT=4000
CORS_ORIGIN=https://tachyon.app

BULLMQ_CONCURRENCY=5

MIGRATION_ENV=production

DB_ENCRYPTION_KEY=  # 32-byte hex; NEVER commit a real value here

NODE_AUTH_TOKEN=  # GitHub PAT (read:packages) — set in DigitalOcean App Platform

SENTRY_DSN=<set-in-do-secrets>

CLERK_PUBLISHABLE_KEY=${tachyon-pg-prod.CLERK_PUBLISHABLE_KEY}
CLERK_SECRET_KEY=${tachyon-pg-prod.CLERK_SECRET_KEY}
CLERK_JWKS_URL=${tachyon-pg-prod.CLERK_JWKS_URL}
CLERK_ISSUER=${tachyon-pg-prod.CLERK_ISSUER}
CLERK_JWKS_CACHE_TTL=600      # JWKS cache TTL in seconds (default 600)

TACHYON_BRAIN_DAILY_CAP=10
ANTHROPIC_API_KEY=

STRIPE_SECRET_KEY=${tachyon-pg-prod.STRIPE_SECRET_KEY}
STRIPE_WEBHOOK_SECRET=${tachyon-pg-prod.STRIPE_WEBHOOK_SECRET}
STRIPE_PRICE_ID_BYOK=${tachyon-pg-prod.STRIPE_PRICE_ID_BYOK}
STRIPE_PRICE_ID_TACHYON_HOSTED=${tachyon-pg-prod.STRIPE_PRICE_ID_TACHYON_HOSTED}